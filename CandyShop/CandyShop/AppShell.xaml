<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="CandyShop.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:CandyShop.Views"
    Title="CandyShop">

    <ShellContent
        Title="Candies"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

    <ShellContent
        Title="Edit Candy"
        ContentTemplate="{DataTemplate local:EditPage}"
        Route="EditPage" />

    <ShellContent
        Title="Sell Candy"
        ContentTemplate="{DataTemplate local:SellCandyPage}"
        Route="SellCandyPage" />
    
    <ShellContent
        Title="Reports"
        ContentTemplate="{DataTemplate local:ReportPage}"
        Route="ReportPage" />

</Shell>
